# evaluator_skill 环境变量配置模板
# 复制为 .env 并填入实际值：cp .env.example .env

# ============ PostgreSQL ============
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DBNAME=postgres
PG_USER=root
PG_PASSWORD=CHANGE_ME
PG_SCHEMA=chat_qms

# ============ Milvus ============
MILVUS_URI=http://localhost:19530
MILVUS_DB=sunny_agent
MILVUS_USER=root
MILVUS_PASSWORD=CHANGE_ME

# ============ Embedding API ============
EMBEDDING_API_BASE=https://your-embedding-api/v1/embeddings
EMBEDDING_API_KEY=CHANGE_ME
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_TIMEOUT=60

# ============ LLM (用于生成假设性问题) ============
LLM_MODEL=anthropic/claude-sonnet-4-20250514
LLM_TIMEOUT=60

# ============ 向量维度 ============
VECTOR_DIM=1024
